# --- Java & Maven (Essencial) ---
target/
*.class
*.jar
*.war
*.ear
*.nar

# Wrapper do Maven (Opcional - deixe se quiser versionar o wrapper)
!.mvn/wrapper/maven-wrapper.jar

# --- Logs & Arquivos Temporários ---
*.log
logs/
temp/
/routes/app.log
hs_err_pid*

