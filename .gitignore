.idea/
*.iml
*.iws
*.ipr
.vscode/
.classpath
.project
.settings/
.springBeans
bin/

# --- Sistema Operacional ---
.DS_Store
Thumbs.db
ehthumbs.db

# --- Segurança & Ambiente Local (CRÍTICO) ---
.env
application-local.properties
/routes/src/main/resources/application-local.properties

# --- Docker (Se não quiser versionar builds locais) ---
