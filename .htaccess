# .htaccess na raiz do projeto
RewriteEngine On
RewriteBase /

# Se o arquivo ou diretĂłrio solicitado existir fisicamente (como /api/auth.php), use-o diretamente
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# --- AutenticaĂ§ĂŁo ---
RewriteRule ^login$ auth.php?action=login [L,QSA]
RewriteRule ^logout$ auth.php?action=logout [L,QSA]
RewriteRule ^dados_usuario$ auth.php?action=check [L,QSA]

# --- Financeiro (Boletos e Contas) ---
# Baixar (Pagar)
RewriteRule ^registros/([0-9]+)/baixar$ financeiro.php?id=$1&action=baixar [L,QSA]
# CRUD Individual (GET um, DELETE, PUT)
RewriteRule ^registros/([0-9]+)$ financeiro.php?id=$1 [L,QSA]
# Listagem e CriaĂ§ĂŁo
RewriteRule ^registros$ financeiro.php [L,QSA]
RewriteRule ^novo_boleto$ financeiro.php [L,QSA]

# --- Dashboard & Fluxo ---
RewriteRule ^dashboard$ dashboard.php [L,QSA]
RewriteRule ^fluxo/movimento$ fluxo.php?action=salvar [L,QSA]
RewriteRule ^fluxo$ fluxo.php [L,QSA]

# --- UtilitĂˇrios e Cadastros ---
RewriteRule ^ler_codigo$ boleto.php [L,QSA]
RewriteRule ^fornecedores/([0-9]+)$ fornecedores.php?id=$1 [L,QSA]
RewriteRule ^fornecedores$ fornecedores.php [L,QSA]
RewriteRule ^exportar$ exportar.php [L,QSA]

# --- Admin (Logs e UsuĂˇrios) ---
RewriteRule ^logs$ admin.php?resource=logs [L,QSA]
RewriteRule ^usuarios$ admin.php?resource=usuarios [L,QSA]

# Caso contrĂˇrio, redirecione para o index.html (Suporte para SPA)
RewriteRule ^ index.html [L]